<?xml version="1.0" ?>
<robot name="quad_drohne">

  <!-- Zentrale Kugel -->
  <link name="body">
    <visual>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1"/>
    </inertial>
  </link>

  <!-- Arme -->
  <!-- vorne -->
  <link name="arm_front">
    <visual>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>
  <joint name="joint_front" type="fixed">
    <parent link="body"/>
    <child link="arm_front"/>
    <origin xyz="0.3 0 0"/>
  </joint>

  <!-- hinten -->
  <link name="arm_back">
    <visual>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>
  <joint name="joint_back" type="fixed">
    <parent link="body"/>
    <child link="arm_back"/>
    <origin xyz="-0.3 0 0"/>
  </joint>

  <!-- links -->
  <link name="arm_left">
    <visual>
      <geometry>
        <box size="0.05 0.4 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>
  <joint name="joint_left" type="fixed">
    <parent link="body"/>
    <child link="arm_left"/>
    <origin xyz="0 -0.3 0"/>
  </joint>

  <!-- rechts -->
  <link name="arm_right">
    <visual>
      <geometry>
        <box size="0.05 0.4 0.05"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>
  <joint name="joint_right" type="fixed">
    <parent link="body"/>
    <child link="arm_right"/>
    <origin xyz="0 0.3 0"/>
  </joint>

  <!-- Propeller (kleine Zylinder oben drauf) -->
  <!-- vorne -->
  <link name="prop_front">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.08"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>
  <joint name="joint_prop_front" type="fixed">
    <parent link="arm_front"/>
    <child link="prop_front"/>
    <origin xyz="0.2 0 0.05"/>
  </joint>

  <!-- hinten -->
  <link name="prop_back">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="joint_prop_back" type="fixed">
    <parent link="arm_back"/>
    <child link="prop_back"/>
    <origin xyz="-0.2 0 0.05"/>
  </joint>

  <!-- links -->
  <link name="prop_left">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="joint_prop_left" type="fixed">
    <parent link="arm_left"/>
    <child link="prop_left"/>
    <origin xyz="0 -0.2 0.05"/>
  </joint>

  <!-- rechts -->
  <link name="prop_right">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="joint_prop_right" type="fixed">
    <parent link="arm_right"/>
    <child link="prop_right"/>
    <origin xyz="0 0.2 0.05"/>
  </joint>

</robot>
